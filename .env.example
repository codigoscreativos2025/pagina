# JWT Secret - Genera una cadena aleatoria segura
JWT_SECRET=change-this-to-a-secure-random-string

# Google OAuth (obtén de Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenAI API Key (obtén de platform.openai.com)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic API Key (opcional, para modelos Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Meta WhatsApp API (obtén de Meta Developer Portal)
META_PHONE_NUMBER_ID=your-phone-number-id
META_ACCESS_TOKEN=your-access-token
